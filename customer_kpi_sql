WITH customer_data AS(
 SELECT
  f.customer_id,
  MIN(f.order_date) AS first_order_date,
  MAX(f.order_date) AS latest_order_date,
  COUNT(*) AS order_count,
  SUM(f.order_amount) AS total_sales,
  AVG(f.order_amount) avg_order_amount
 FROM
  fact_orders AS f
 GROUP BY
  f.customer_id)

SELECT
 customer_id,
 first_order_date,
 latest_order_date,
 order_count,
 total_sales,
 avg_order_amount,

 DATE_DIFF(latest_order_date,
  first_order_date, DAY)  AS days_from_first_order,

 DENSE_RANK() OVER(ORDER BY total_sales
  DESC) AS customer_rank

FROM
 customer_data
;
